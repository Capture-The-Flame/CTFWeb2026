.about-section {
  position: relative;
  z-index: 5; /* above water & grass ? */
  display: flex;
  justify-content: center;
  padding: 2rem 0 4rem;
}

/* FRAME */
.about-frame {
  position: relative;
  width: 92vw;
  max-width: 1920px;
  justify-self: center;
}

/* SVG IMAGE */
.about-scroll {
  width: 100%;
  height: auto;
  display: block;
  pointer-events: none;
  user-select: none;
}

/* CONTENT OVERLAY */
.about-content {
  position: absolute;
  inset: 0;

  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;

  /* frames the text inside the scroll */
  padding: 14% 10%;

  text-align: center;
}

/* TITLE */
.about-title {
  font-size: clamp(1.3rem, 2.5vw, 2rem);
  margin-bottom: 1rem;
}

/* BODY TEXT */
.about-content p {
  max-width: 800px;
  line-height: 1.6;
  font-size: 1rem;
}
