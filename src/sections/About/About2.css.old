.about1 {
  position: relative;
  width: 100%;
  overflow: hidden;
}

.scroll-wrapper {
  width: 100vw;
  aspect-ratio: 400 / 111.3;

  /*background-image: url("../../assets/backgroundArt/vertical_scroll_00_transparent.svg");
  background-repeat: no-repeat;
  background-position: center;
  background-size: cover;*/

  display: flex;
  justify-content: center;
  align-items: center;
}

.about-content {
  max-width: 60%;
  text-align: center;
  padding: 2rem;
  color: #000000;
}

.about-content h2 {
  margin-bottom: 0.75rem;
}

.about-content p {
  line-height: 1.6;
}
